{
  "public_id": "abc-xyz-123",
  "name": "API Health Check - example.com",
  "type": "api",
  "subtype": "http",
  "status": "live",
  "message": "{{#is_alert}}\nHealth check for https://api.example.com/health has failed in {{#each failing_locations}} {{location}} {{/each}}.\n\nNotify: @pagerduty-oncall @slack-sre-alerts\n{{/is_alert}}\n\n{{#is_recovery}}\nHealth check for https://api.example.com/health has recovered.\n{{/is_recovery}}",
  "tags": [
    "env:prod",
    "team:platform",
    "service:api-gateway",
    "managed-by:terraform"
  ],
  "config": {
    "request": {
      "method": "GET",
      "url": "https://api.example.com/health",
      "headers": {
        "Accept": "application/json",
        "X-Datadog-Origin": "synthetics"
      },
      "timeout": 30
    },
    "assertions": [
      {
        "type": "statusCode",
        "operator": "is",
        "target": 200
      },
      {
        "type": "responseTime",
        "operator": "lessThan",
        "target": 2000
      },
      {
        "type": "body",
        "operator": "contains",
        "target": "\"status\":\"ok\""
      }
    ],
    "variables": []
  },
  "options": {
    "tick_every": 60,
    "min_failure_duration": 0,
    "min_location_failed": 1,
    "follow_redirects": true,
    "allow_insecure": false,
    "retry": {
      "count": 2,
      "interval": 300
    },
    "monitor_options": {
      "notify_audit": false,
      "locked": false,
      "include_tags": true,
      "renotify_interval": 120
    }
  },
  "locations": [
    "aws:us-east-1",
    "aws:eu-west-1",
    "aws:ap-southeast-1"
  ],
  "created_at": "2024-06-15T09:23:11.000000+00:00",
  "modified_at": "2025-01-08T14:47:33.000000+00:00",
  "created_by": {
    "handle": "jane.doe@example.com",
    "name": "Jane Doe"
  },
  "modified_by": {
    "handle": "john.smith@example.com",
    "name": "John Smith"
  },
  "monitor_id": 98234571
}
